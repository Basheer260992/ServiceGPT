PORT=5000
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d
# STORAGE: "json" (lowdb) or "mongo" (mongoose)
STORAGE=json
MONGODB_URI=mongodb://localhost:27017/servicegpt
CORS_ORIGIN=http://localhost:5173

# ServiceNow default instance (fallback when no instance is selected)
SERVICENOW_INSTANCE=dev347798
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=
SERVICENOW_URL=https://dev347798.service-now.com

# ServiceNow instance-specific credentials
SERVICENOW_USERNAME_inst-2=admin
SERVICENOW_PASSWORD_inst-2=
SERVICENOW_URL_inst-2=https://dev347798.service-now.com

SERVICENOW_USERNAME_inst-3=admin
SERVICENOW_PASSWORD_inst-3=
SERVICENOW_URL_inst-3=https://dev379111.service-now.com

SERVICENOW_USERNAME_inst-4=admin
SERVICENOW_PASSWORD_inst-4=
SERVICENOW_URL_inst-4=https://dev388985.service-now.com

SERVICENOW_USERNAME_inst-5=admin
SERVICENOW_PASSWORD_inst-5=
SERVICENOW_URL_inst-5=https://dev347798.service-now.com

# Google Gemini / Gemini API key for general chat (optional - incident creation works without it)
# You can set either GOOGLE_API_KEY or GEMINI_API_KEY here.
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=2048

# Anthropic Claude API key for general chat (optional - incident creation works without it)
ANTHROPIC_API_KEY=
