{
  "name": "servicegpt-portal",
  "private": true,
  "version": "1.0.0",
  "description": "ServiceGPT Enterprise Portal - run both frontend and backend",
  "scripts": {
    "install:all": "npm --prefix backend install && npm --prefix frontend install",
    "dev:backend": "npm --prefix backend start",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev": "concurrently -k -n backend,frontend -c blue,magenta \"npm:dev:backend\" \"npm:dev:frontend\"",
    "build": "npm --prefix frontend run build",
    "seed": "node backend/src/utils/seed.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
